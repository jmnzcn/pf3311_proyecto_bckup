  m_Script: {fileID: 11500000, guid: 584bf68737e98ab4993bdc539a04ebcd, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MyProject.QuestionManager
  questionTextDisplay: {fileID: 99619163}
  optionButtonGroup: {fileID: 729101798}
  btnA_Button: {fileID: 2105385441}
  btnB_Button: {fileID: 89765883}
  btnC_Button: {fileID: 1535391569}
  btnD_Button: {fileID: 266601961}
  btnA_Text: {fileID: 129617962}
  btnB_Text: {fileID: 714308287}
  btnC_Text: {fileID: 1225354609}
  btnD_Text: {fileID: 1805420045}
  characterModel: {fileID: 1714685653}
  nextButton: {fileID: 232966929}
  askForHelpButton: {fileID: 604848319}
  inputField: {fileID: 73872383}
  questionCounterText: {fileID: 2128450485}
  myScrollRect: {fileID: 649636107}
  questionScrollSensitivity: 45
  progressBar_Bg: {fileID: 744186514}
  finalOptionsPanel: {fileID: 1855528722}
  surveyButton: {fileID: 1876326581}
  anotherScenarioButton: {fileID: 1083023785}
  finalizeSessionButton: {fileID: 1432477900}
  surveyUrl: 
  surveyCodeEntryId: 
  exitPopupPanel: {fileID: 2003379495}
  safeExitPopup: {fileID: 435437277}
  farewellPanel: {fileID: 1096901312}
  Consent_Overlay: {fileID: 1478007416}
  progressFill: {fileID: 1786839601}
  totalQuestions: 6
  experimentLogic: {fileID: 617762683}
  dataLogger: {fileID: 854952865}
  scenarios:
  - scenarioName: "Condici\xF3n A \u2014 Sin Asistencia"
    surveyUrl: https://docs.google.com/forms/d/1eXYTw-5RbUbLtk1trghoP2XejZCsHZs6Fyk8uuhUeak/viewform
    surveyCodeEntryId: entry.1305913349
    questions:
    - situation: "REGLAS\r\n\u2022 Dolor en el pecho O dificultad para respirar \u2192
        Prioridad 1 (Inmediata), sin excepci\xF3n.\r\n\u2022 65 a\xF1os o m\xE1s
        Y fiebre > 38\xB0C \u2192 Prioridad 2 (Urgente).\r\n\u2022 Condici\xF3n cr\xF3nica
        documentada \u2192 sube un nivel respecto al calculado (salvo P1).\r\n\u2022
        Todos los dem\xE1s casos \u2192 Prioridad 3 (Normal).\r\n\r\nSITUACI\xD3N:
        Ana, 58 a\xF1os, sin condiciones cr\xF3nicas. Fiebre 38.4\xB0C, dolor moderado
        en articulaciones. Sin dolor en el pecho ni dificultad para respirar.\r\n\r\nPREGUNTA\r\n\xBFCu\xE1l
        es la prioridad correcta para Ana?"
      optA: "Prioridad 1 \u2014 Inmediata"
      optB: "Prioridad 2 \u2014 Edad + Fiebre"
      optC: "Prioridad 3 \u2014 Normal"
      optD: "Prioridad 2 \u2014 Solo Fiebre"
      correctOption: C
    - situation: "REGLAS\r\n\u2022 Acceso imposible O brecha de seguridad confirmada
        \u2192 Prioridad 1 (Cr\xEDtico), sin excepci\xF3n.\r\n\u2022 Contrato empresarial
        Y ticket sin resoluci\xF3n > 8 h \u2192 Prioridad 2 (Alto).\r\n\u2022 M\xE1s
        de 5 usuarios afectados simult\xE1neamente \u2192 sube un nivel (salvo P1).\r\n\u2022
        Todos los dem\xE1s casos \u2192 Prioridad 3 (Normal).\r\n\r\nSITUACI\xD3N:
        Marco, usuario individual sin contrato empresarial. M\xF3dulo de reportes
        lento pero accesible. Sin brecha de seguridad. Problema afecta a otros 7
        usuarios. Ticket: 4 h sin resoluci\xF3n.\r\n\r\nPREGUNTA\r\n\xBFCu\xE1l es
        la prioridad correcta del ticket de Marco?"
      optA: "Prioridad 1 \u2014 Cr\xEDtico"
      optB: "Prioridad 2 \u2014 Usuarios"
      optC: "Prioridad 3 \u2014 Normal"
      optD: "Prioridad 2 \u2014 Contrato"
      correctOption: B
    - situation: "REGLAS\r\n\u2022 Sin antivirus activo O en lista negra \u2192 Acceso
        Denegado, sin excepci\xF3n.\r\n\u2022 Departamento TI Y fuera de horario
        laboral (despu\xE9s de las 6pm) \u2192 Acceso Restringido (solo lectura).\r\n\u2022
        Dispositivo personal Y sin aprobaci\xF3n de trabajo remoto \u2192 Acceso
        Denegado.\r\n\u2022 Todos los dem\xE1s casos \u2192 Acceso Permitido.\r\n\r\nSITUACI\xD3N:
        Luc\xEDa, departamento TI, 7:30 pm. Laptop corporativa, antivirus activo,
        no en lista negra. Tiene aprobaci\xF3n de trabajo remoto vigente.\r\n\r\nPREGUNTA\r\n\xBFCu\xE1l
        es el nivel de acceso correcto para Luc\xEDa?"
      optA: "Permitido \u2014 Trabajo Remoto"
      optB: "Denegado \u2014 Fuera de Horario"
      optC: "Permitido \u2014 TI Corporativo"
      optD: "Restringido \u2014 TI Nocturno"
      correctOption: D
    - situation: "REGLAS\r\n\u2022 Historial de mora O en lista de exclusi\xF3n \u2192
        Rechazado autom\xE1tico (sin excepci\xF3n).\r\n\u2022 Monto > $10,000 O antig\xFCedad
        < 2 a\xF1os \u2192 Requiere aval adicional.\r\n\u2022 Cliente Premium \u2192
        antig\xFCedad m\xEDnima para aval baja de 2 a\xF1os a 6 meses.\r\n\u2022
        Pr\xE9stamo para vivienda \u2192 umbral de monto sube a $25,000 (reemplaza
        $10,000).\r\n\r\nSITUACI\xD3N: Laura, cliente Premium, 10 meses de antig\xFCedad.
        Solicita $15,000 para vivienda. Sin mora ni exclusi\xF3n.\r\n\r\nPREGUNTA\r\n\xBFSe
        requiere aval adicional para el pr\xE9stamo de Laura?"
      optA: "S\xED \u2014 Ambas Condiciones"
      optB: "No \u2014 Ambas Neutralizadas"
      optC: "S\xED \u2014 Solo Antig\xFCedad"
      optD: "S\xED \u2014 Solo Monto"
      correctOption: B
    - situation: "REGLAS\r\n\u2022 Promedio \u2265 8.5 Y sin sanciones acad\xE9micas
        activas \u2192 Elegible para Beca de Excelencia.\r\n\u2022 Estudiante de
        primer ingreso \u2192 no puede recibir Beca de Excelencia (requiere historial
        previo).\r\n\u2022 Carrera en \xE1rea prioritaria (ingenier\xEDa, salud,
        educaci\xF3n) \u2192 restricci\xF3n de primer ingreso no aplica.\r\n\u2022
        Sanci\xF3n acad\xE9mica activa \u2192 excluye de cualquier beca, sin excepci\xF3n.\r\n\r\nSITUACI\xD3N:
        Valentina, Ingenier\xEDa (primer a\xF1o), promedio 7.9, sin sanciones acad\xE9micas.
        Solicita la Beca de Excelencia.\r\n\r\nPREGUNTA\r\n\xBFEs Valentina elegible
        para la Beca de Excelencia?"
      optA: "No \u2014 Promedio Insuficiente"
      optB: "S\xED \u2014 \xC1rea Prioritaria"
      optC: "No \u2014 Primer Ingreso"
      optD: "S\xED \u2014 \xC1rea + Sin Sanciones"
      correctOption: A
    - situation: "REGLAS\r\n\u2022 Equipo en producci\xF3n Y falla total \u2192 Prioridad
        Cr\xEDtica (intervenci\xF3n inmediata).\r\n\u2022 Turno nocturno (10 pm\u20136
        am) Y t\xE9cnico de guardia no disponible \u2192 diferir al turno siguiente.\r\n\u2022
        Contrato soporte 24/7 activo \u2192 restricci\xF3n de horario no aplica;
        proveedor puede intervenir a cualquier hora.\r\n\u2022 Todos los dem\xE1s
        casos \u2192 Prioridad Est\xE1ndar (orden de llegada).\r\n\r\nSITUACI\xD3N:
        2 am. Prensa en \xE1rea de producci\xF3n con falla total. Contrato de soporte
        24/7 activo. T\xE9cnico de guardia interno no disponible.\r\n\r\nPREGUNTA\r\n\xBFQu\xE9
        acci\xF3n corresponde para este equipo?"
      optA: "Diferir \u2014 Sin T\xE9cnico"
      optB: "Est\xE1ndar \u2014 Sin T\xE9cnico"
      optC: "Cr\xEDtica \u2014 Contrato 24/7"
      optD: "Diferir \u2014 Horario Prevalece"
      correctOption: C
  - scenarioName: "Condici\xF3n B \u2014 Agente de Texto"
    surveyUrl: https://docs.google.com/forms/d/1MLqIh__LvA7Da5-uJt6izsD-pAyALmO9Je7GlrZpTEg/viewform
    surveyCodeEntryId: entry.434502712
    questions:
    - situation: "REGLAS\r\n\u2022 M\xE1s de 3 ausencias injustificadas \u2192 Reprobado
        autom\xE1tico, sin importar la nota.\r\n\u2022 Nota \u2265 70 en examen final
        Y entreg\xF3 todos los proyectos \u2192 Aprobado.\r\n\u2022 Entreg\xF3 todos
        los proyectos Y nota entre 60 y 69 \u2192 Revisi\xF3n por el profesor.\r\n\u2022
        Todos los dem\xE1s casos \u2192 Reprobado.\r\n\r\nSITUACI\xD3N: Diego, nota
        72 en examen final, entreg\xF3 todos los proyectos. Tuvo 4 ausencias: 2 justificadas
        y 2 injustificadas.\r\n\r\nPREGUNTA\r\n\xBFCu\xE1l es el resultado acad\xE9mico
        de Diego?"
      optA: Aprobado
      optB: "Reprobado \u2014 4 Ausencias"
      optC: "Reprobado \u2014 Todas las Ausencias"
      optD: "Revisi\xF3n \u2014 Ausencias"
      correctOption: A
    - situation: "REGLAS\r\n\u2022 Commit modifica /core O /security \u2192 requiere
        aprobaci\xF3n de 2 revisores antes del merge, sin excepci\xF3n.\r\n\u2022
        Desarrollador con < 1 a\xF1o en el equipo \u2192 +1 revisor adicional sobre
        el m\xEDnimo requerido.\r\n\u2022 Repositorio en modo freeze \u2192 solo
        se permiten commits de tipo hotfix; cualquier otro es bloqueado.\r\n\u2022
        Commit hotfix Y modifica /core o /security \u2192 requisitos de revisores
        aplican normalmente, pero con proceso acelerado.\r\n\r\nSITUACI\xD3N: Repositorio
        en freeze. Andr\xE9s, 8 meses en el equipo. Commit tipo hotfix que modifica
        /core y /security.\r\n\r\nPREGUNTA\r\n\xBFCu\xE1ntos revisores se requieren
        y bajo qu\xE9 proceso?"
      optA: Bloqueado
      optB: "Acelerado \u2014 2 Revisores"
      optC: "Acelerado \u2014 3 Revisores"
      optD: "Acelerado \u2014 2 (Combinado)"
      correctOption: C
    - situation: "REGLAS\r\n\u2022 Gasto sin factura O proveedor no registrado \u2192
        Rechazado autom\xE1tico, sin excepci\xF3n.\r\n\u2022 Monto \u2264 $200 Y
        con factura Y proveedor registrado \u2192 Aprobado autom\xE1ticamente.\r\n\u2022
        Empleado en per\xEDodo de prueba (primeros 90 d\xEDas) \u2192 umbral de aprobaci\xF3n
        baja de $200 a $100 (reemplaza el l\xEDmite).\r\n\u2022 Todos los dem\xE1s
        casos con documentaci\xF3n v\xE1lida \u2192 Requiere aprobaci\xF3n del supervisor.\r\n\r\nSITUACI\xD3N:
        Rosa, 45 d\xEDas en la empresa (per\xEDodo de prueba). Gasto de $150 para
        materiales de oficina. Con factura. Proveedor registrado.\r\n\r\nPREGUNTA\r\n\xBFC\xF3mo
        se procesa la solicitud de gasto de Rosa?"
      optA: "Requiere Supervisor \u2014 Prueba Baja Umbral"
      optB: "Aprobado \u2014 $150 Dentro del L\xEDmite"
      optC: "Aprobado \u2014 Prueba No Aplica Aqu\xED"
      optD: "Rechazado \u2014 Proveedor en Prueba"
      correctOption: A
    - situation: "REGLAS\r\n\u2022 Acceso si clearance \u2265 nivel del archivo,
        O si tiene autorizaci\xF3n expl\xEDcita firmada \u2014 pero no si est\xE1
        en lista de suspensi\xF3n (sin excepci\xF3n).\r\n\u2022 Autorizaci\xF3n expl\xEDcita
        v\xE1lida solo si: emitida hace < 90 d\xEDas Y por supervisor nivel 3 o superior.\r\n\r\nSITUACI\xD3N:
        Archivo nivel 4. Sof\xEDa, clearance nivel 3. Autorizaci\xF3n expl\xEDcita
        para ese archivo, firmada hace 85 d\xEDas por supervisor nivel 3. Sof\xEDa
        no est\xE1 suspendida.\r\n\r\nPREGUNTA\r\n\xBFPuede Sof\xEDa acceder al archivo?"
      optA: "No \u2014 Clearance Insuficiente"
      optB: "No \u2014 Supervisor Insuficiente"
      optC: "No \u2014 Plazo L\xEDmite"
      optD: "S\xED \u2014 Autorizaci\xF3n V\xE1lida"
      correctOption: D
    - situation: "REGLAS\r\n\u2022 Paquete > 30 kg O dimensiones > 100 cm en cualquier
        lado \u2192 Env\xEDo Especial (cotizaci\xF3n manual), sin excepci\xF3n.\r\n\u2022
        Membres\xEDa premium Y destino nacional \u2192 Env\xEDo Gratis Express.\r\n\u2022
        Valor declarado > $500 \u2192 seguro obligatorio adicional, independientemente
        del tipo de env\xEDo.\r\n\u2022 Todos los dem\xE1s casos \u2192 Env\xEDo
        Est\xE1ndar.\r\n\r\nSITUACI\xD3N: Carlos, membres\xEDa premium. Paquete nacional,
        5 kg, 40\xD730\xD720 cm, valor declarado $650.\r\n\r\nPREGUNTA\r\n\xBFQu\xE9
        tipo de env\xEDo aplica para Carlos?"
      optA: "Est\xE1ndar"
      optB: Express + Seguro
      optC: Especial
      optD: Express sin Cargos
      correctOption: B
    - situation: "REGLAS\r\n\u2022 Ticket escala a Nivel 2 si: > 4 h sin resoluci\xF3n
        Y mismo problema reportado > 1 vez en 30 d\xEDas. Si solo se cumple una \u2192
        permanece en N1.\r\n\u2022 Nivel 2 escala a Nivel 3 solo si el usuario tiene
        contrato SLA Premium. Sin ese contrato, m\xE1ximo Nivel 2.\r\n\u2022 P\xE9rdida
        de datos confirmada \u2192 escala directamente a Nivel 3, sin pasar por reglas
        anteriores (salvo ticket cerrado).\r\n\r\nSITUACI\xD3N: Ticket de Isabel:
        6 h abierto. Report\xF3 el mismo problema 3 veces en 30 d\xEDas. Sin SLA
        Premium. Soporte confirm\xF3 p\xE9rdida parcial de datos. Ticket abierto.\r\n\r\nPREGUNTA\r\n\xBFA
        qu\xE9 nivel escala el ticket de Isabel?"
      optA: Nivel 1
      optB: "Nivel 2 \u2014 Sin SLA"
      optC: "Nivel 2 \u2014 Secuencia"
      optD: "Nivel 3 \u2014 P\xE9rdida de Datos"
      correctOption: D
  - scenarioName: "Condici\xF3n C \u2014 Agente Virtual"
    surveyUrl: https://docs.google.com/forms/d/e/1FAIpQLSfIVI1RNATtR3KE0fSmj91lGhI1SvHhyyWWGOIXj_vB-2Z1eg/viewform
    surveyCodeEntryId: entry.175273376
    questions:
    - situation: "REGLAS\r\n\u2022 Libro en categor\xEDa \"referencia exclusiva\"
        O fuera de pr\xE9stamo en el sistema \u2192 No disponible para pr\xE9stamo,
        sin excepci\xF3n.\r\n\u2022 Usuario con membres\xEDa activa Y sin multas
        pendientes \u2192 puede tomar hasta 3 libros.\r\n\u2022 Usuario de posgrado
        \u2192 l\xEDmite de pr\xE9stamo sube de 3 a 5 libros (reemplaza el m\xE1ximo).\r\n\u2022
        Todos los dem\xE1s casos \u2192 usuario en lista de espera.\r\n\r\nSITUACI\xD3N:
        Carlos, membres\xEDa activa de biblioteca. Tiene una multa de $0.50 por retraso.
        Estudia posgrado. Solicita pr\xE9stamo de 2 libros. Ninguno es de referencia
        exclusiva ni est\xE1 fuera de pr\xE9stamo.\r\n\r\nPREGUNTA\r\n\xBFPuede Carlos
        tomar prestados los 2 libros?"
      optA: "S\xED \u2014 Membres\xEDa Activa"
      optB: "S\xED \u2014 Posgrado Ampl\xEDa L\xEDmite"
      optC: "S\xED \u2014 Posgrado Cancela Multa"
      optD: "No \u2014 Lista de Espera"
      correctOption: D
    - situation: "REGLAS\r\n\u2022 Producto modificado O da\xF1o por accidente \u2192
        Garant\xEDa Nula (sin excepci\xF3n).\r\n\u2022 Defecto de fabricaci\xF3n
        documentado Y dentro de los primeros 12 meses \u2192 Reemplazo gratuito.\r\n\u2022
        Plan de Protecci\xF3n Extendida \u2192 cobertura de defecto de fabricaci\xF3n
        ampl\xEDa a 24 meses (reemplaza 12).\r\n\u2022 Dem\xE1s casos dentro del
        per\xEDodo vigente \u2192 Reparaci\xF3n con costo cubierto.\r\n\r\nSITUACI\xD3N:
        Miguel, televisor comprado hace 15 meses, Plan de Protecci\xF3n Extendida
        activo. T\xE9cnico document\xF3 defecto de fabricaci\xF3n en la placa base.
        Sin modificaciones ni accidentes.\r\n\r\nPREGUNTA\r\n\xBFQu\xE9 cobertura
        aplica para Miguel?"
      optA: "Nula \u2014 Plazo Vencido"
      optB: "Reemplazo \u2014 24 Meses"
      optC: "Reparaci\xF3n Cubierta"
      optD: "Reemplazo \u2014 Plan Total"
      correctOption: B
    - situation: "REGLAS\r\n\u2022 Zona Nivel 4 O visitante en lista de restricci\xF3n
        \u2192 Denegado (sin excepci\xF3n).\r\n\u2022 Visitante externo Y patrocinador
        no confirm\xF3 la visita \u2192 Denegado hasta confirmaci\xF3n.\r\n\u2022
        Credencial temporal v\xE1lida (emitida < 24 h) Y acompa\xF1ado por empleado
        permanente \u2192 acceso zonas N1\u2013N3 sin confirmaci\xF3n del patrocinador.\r\n\u2022
        Fuera de horario laboral (antes de 8 am o despu\xE9s de 6 pm) O d\xEDa festivo
        \u2192 solo accesos de emergencia verificados; cualquier otro: denegado,
        sin excepci\xF3n.\r\n\r\nSITUACI\xD3N: 7:30 am. Diana, visitante externa,
        credencial temporal emitida hace 3 h, acompa\xF1ada por empleado permanente.
        Patrocinador no confirm\xF3. Zona Nivel 2.\r\n\r\nPREGUNTA\r\n\xBFQu\xE9
        resultado aplica para Diana?"
      optA: "Permitido \u2014 Credencial"
      optB: "Denegado \u2014 Sin Patrocinio"
      optC: "Denegado \u2014 Fuera de Horario"
      optD: "Permitido \u2014 Zona N2"
      correctOption: C
    - situation: "REGLAS\r\n\u2022 Gasto anual > $2,000 Y 3 o m\xE1s renovaciones
        consecutivas \u2192 descuento 20%.\r\n\u2022 Plan B\xE1sico \u2192 umbral
        de gasto anual baja a $1,500 (reemplaza $2,000).\r\n\u2022 Renovaci\xF3n
        tard\xEDa \u2192 recargo 10% sobre precio base (independiente de cualquier
        descuento).\r\n\u2022 Cancela dentro de los primeros 30 d\xEDas del ciclo
        \u2192 reembolso proporcional; sin descuento ni recargo.\r\n\r\nSITUACI\xD3N:
        Pedro, plan B\xE1sico, 4 renovaciones consecutivas, gasto anual $1,700. Renueva
        con 15 d\xEDas de retraso. No est\xE1 cancelando.\r\n\r\nPREGUNTA\r\n\xBFQu\xE9
        condiciones aplican a la renovaci\xF3n de Pedro?"
      optA: Descuento + Recargo
      optB: Solo Recargo
      optC: Solo Descuento
      optD: Sin Cambios
      correctOption: A
    - situation: "REGLAS\r\n\u2022 Producto abierto O m\xE1s de 30 d\xEDas desde
        la compra \u2192 No procede reembolso, sin excepci\xF3n.\r\n\u2022 Defecto
        de f\xE1brica documentado Y reportado en los primeros 7 d\xEDas \u2192 Reembolso
        completo.\r\n\u2022 Membres\xEDa Gold \u2192 plazo de devoluci\xF3n se extiende
        a 60 d\xEDas (reemplaza los 30 d\xEDas, solo para Gold).\r\n\u2022 Todos
        los dem\xE1s casos que cumplen el plazo \u2192 Cr\xE9dito en tienda.\r\n\r\nSITUACI\xD3N:
        Rosa, membres\xEDa Gold. Compr\xF3 el producto hace 20 d\xEDas y lo abri\xF3
        para probarlo. No presenta defecto de f\xE1brica.\r\n\r\nPREGUNTA\r\n\xBFQu\xE9
        resultado aplica para Rosa?"
      optA: "Cr\xE9dito \u2014 Plazo 60 D\xEDas"
      optB: Reembolso Completo
      optC: "Sin Reembolso \u2014 Abierto"
      optD: "Cr\xE9dito \u2014 Gold Mensual"
      correctOption: C
    - situation: "REGLAS\r\n\u2022 5 o m\xE1s d\xEDas laborados consecutivos \u2192
        requiere aprobaci\xF3n de RRHH para asignarse.\r\n\u2022 Turno nocturno Y
        antig\xFCedad < 6 meses \u2192 prohibido asignar al turno nocturno.\r\n\u2022
        Escasez cr\xEDtica (< 3 disponibles) \u2192 suspende restricci\xF3n por d\xEDas
        consecutivos Y restricci\xF3n nocturna, EXCEPTO el requisito de aprobaci\xF3n
        de RRHH.\r\n\u2022 Supervisor certificado \u2192 restricci\xF3n nocturna
        no aplica (puede asignarse a cualquier turno).\r\n\r\nSITUACI\xD3N: Felipe,
        4 meses de antig\xFCedad, supervisor certificado. 5 d\xEDas consecutivos
        trabajados. Escasez cr\xEDtica (2 disponibles). Turno nocturno.\r\n\r\nPREGUNTA\r\n\xBFPuede
        Felipe ser asignado al turno nocturno?"
      optA: "S\xED \u2014 Sin Restricciones"
      optB: "No \u2014 Requiere RRHH"
      optC: "S\xED \u2014 Escasez Total"
      optD: "S\xED \u2014 Con RRHH"
      correctOption: D
  currentQuestionIndex: 0
